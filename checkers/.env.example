# =============================================================================
# Glazetopia Checkers — Environment Variables
# =============================================================================
# This file documents all env vars used across the project. Copy values into
# the appropriate local .env file for each app:
#
#   apps/web/.env.local  ← backend secrets (Supabase, JWT, bot shared secret)
#   apps/bot/.env.local  ← bot secrets (Discord token, bot shared secret)
#
# NEVER commit a real .env.local. NEVER paste real secrets into chat.
# =============================================================================

# ============================================================================
# Backend secrets (apps/web)
# ============================================================================

# Supabase
# Local (from `supabase status` output):
#   SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used to sign session tokens. Backend ONLY.
# Generate: openssl rand -hex 32
CHECKERS_JWT_SECRET=

# HMAC shared secret — used to authenticate bot → backend calls.
# Must be IDENTICAL in apps/web and apps/bot environments.
# Generate: openssl rand -hex 32
CHECKERS_BOT_SHARED_SECRET=

# Where the game frontend lives — used to build launch URLs.
# Local: http://localhost:3000
CHECKERS_GAME_URL=http://localhost:3000

# Game / progression
CHECKERS_MARKS_REQUIRED=3
CHECKERS_MIN_MOVES_FOR_WIN=10
CHECKERS_SESSION_TTL_MINUTES=15
CHECKERS_COOLDOWN_SECONDS=30
CHECKERS_MAX_DAILY_SESSIONS=20

# ============================================================================
# Bot (apps/bot)
# ============================================================================

# Discord
# Application ID is public — from Developer Portal.
DISCORD_APPLICATION_ID=1504445787663499304
DISCORD_PUBLIC_KEY=264ea61d96fdc8cb9981511acf8d4d7cccf0e13973fb22f0dfe4a9f38b3f65d2
# Guild ID is public — from server settings (Developer Mode on).
DISCORD_GUILD_ID=1263855713353207900
# Role ID for level-pass (used in Phase 5; not consumed in Phase 4).
DISCORD_LEVEL_PASSED_ROLE_ID=1504455432260026478

# Bot token — SECRET. Reset via Developer Portal → Bot tab.
DISCORD_BOT_TOKEN=

# Base URL of the backend the bot calls. Local: http://localhost:3000.
# In production: your Vercel URL.
CHECKERS_BACKEND_URL=http://localhost:3000

# Bot-side per-user cooldown in seconds. Backend cooldown is the real defense.
BOT_COMMAND_COOLDOWN_SECONDS=5

# ============================================================================
# Common
# ============================================================================

NODE_ENV=development
