# =============================================================================
# Glazetopia Checkers — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values locally.
# NEVER commit .env.local to git.
#
# Local development uses Supabase CLI (npm run db:start). The CLI prints
# the local URL and keys; copy them into .env.local.
# =============================================================================

# ----- Supabase -----
# Local (from `supabase status` output):
#   SUPABASE_URL=http://127.0.0.1:54321
#   SUPABASE_ANON_KEY=<printed by supabase status>
#   SUPABASE_SERVICE_ROLE_KEY=<printed by supabase status>
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Discord Bot (used in Phase 4+) -----
DISCORD_APPLICATION_ID=1504445787663499304
DISCORD_PUBLIC_KEY=264ea61d96fdc8cb9981511acf8d4d7cccf0e13973fb22f0dfe4a9f38b3f65d2
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=1263855713353207900
DISCORD_LEVEL_PASSED_ROLE_ID=1504455432260026478

# ----- Backend secrets -----
# Generate strong random strings, e.g. `openssl rand -hex 32`
CHECKERS_JWT_SECRET=
CHECKERS_BOT_SHARED_SECRET=

# ----- URLs -----
# Where the game frontend lives (used by the bot to build launch links in Phase 4).
# Local dev: http://localhost:3000
CHECKERS_GAME_URL=http://localhost:3000

# ----- Game / progression tunables -----
CHECKERS_MARKS_REQUIRED=3

# ----- Anti-cheat tunables -----
CHECKERS_MIN_MOVES_FOR_WIN=10
CHECKERS_SESSION_TTL_MINUTES=15
CHECKERS_COOLDOWN_SECONDS=30
CHECKERS_MAX_DAILY_SESSIONS=20

# ----- Node env -----
NODE_ENV=development
