{
  "name": "@glazetopia/bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot for Glazetopia Checkers — thin shim, no DB or JWT access",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "register-commands": "tsx src/scripts/register-commands.ts"
  },
  "dependencies": {
    "discord.js": "^14.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
